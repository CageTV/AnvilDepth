<Window x:Class="AnvilDepth.MainWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="AnvilDepth RTX" Height="850" Width="1350" Background="#0A0A0A" WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions><ColumnDefinition Width="380"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
        <Border Grid.Column="0" Background="#121212" BorderBrush="#27272A" BorderThickness="0,0,1,0">
            <ScrollViewer Padding="20">
                <StackPanel>
                    <TextBlock Text="ANVILDEPTH" FontWeight="Bold" FontSize="20" Foreground="White"/>
                    <TextBlock Text="RTX GPU Accelerated - VS2026" FontSize="11" Foreground="#8B5CF6" Margin="0,2,0,20"/>
                    <Border Background="#1E1E1E" CornerRadius="8" Padding="12" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="GPU STATUS" FontSize="10" Foreground="#71717A"/>
                            <TextBlock x:Name="GpuStatusText" Text="Checking RTX..." Foreground="#22C55E" FontSize="12" FontWeight="SemiBold"/>
                            <TextBlock x:Name="ModelStatusText" Text="Model: Depth Anything V2" FontSize="10" Foreground="#52525B" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border x:Name="DropZone" Background="#1A1A1A" BorderBrush="#3F3F46" BorderThickness="2" CornerRadius="12" Height="160" AllowDrop="True" Drop="DropZone_Drop" DragOver="DropZone_DragOver" MouseDown="DropZone_MouseDown">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock x:Name="DropText" Text="Drop Image or Click" TextAlignment="Center" Foreground="#71717A" FontSize="12" Margin="0,8,0,0"/>
                            <Image x:Name="PreviewImage" MaxHeight="100" Visibility="Collapsed" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>
                    <StackPanel Margin="0,20,0,0">
                        <TextBlock Text="Strength" Foreground="#A1A1AA" FontSize="12"/>
                        <Slider x:Name="StrengthSlider" Minimum="0.2" Maximum="2.5" Value="1.0" Margin="0,4,0,4" ValueChanged="Slider_ValueChanged"/>
                        <TextBlock x:Name="StrengthLabel" Text="1.0" FontSize="10" Foreground="#52525B" Margin="0,0,0,12"/>
                        <TextBlock Text="Detail Boost" Foreground="#A1A1AA" FontSize="12"/>
                        <Slider x:Name="DetailSlider" Minimum="0" Maximum="1" Value="0.7" Margin="0,4,0,4" ValueChanged="Slider_ValueChanged"/>
                        <TextBlock x:Name="DetailLabel" Text="0.7" FontSize="10" Foreground="#52525B" Margin="0,0,0,12"/>
                        <TextBlock Text="Gamma" Foreground="#A1A1AA" FontSize="12"/>
                        <Slider x:Name="GammaSlider" Minimum="0.5" Maximum="2.5" Value="1.0" Margin="0,4,0,4" ValueChanged="Slider_ValueChanged"/>
                        <TextBlock x:Name="GammaLabel" Text="1.0" FontSize="10" Foreground="#52525B" Margin="0,0,0,12"/>
                        <CheckBox x:Name="InvertCheck" Content="Invert - White = High" IsChecked="True" Foreground="#D4D4D8" FontSize="12" Margin="0,8,0,8"/>
                        <CheckBox x:Name="RemoveBgCheck" Content="Remove Background to Pure Black" IsChecked="True" Foreground="#D4D4D8" FontSize="12" Margin="0,0,0,8"/>
                        <CheckBox x:Name="HighQualityCheck" Content="High Quality Tiled 2K" IsChecked="True" Foreground="#D4D4D8" FontSize="12" Margin="0,0,0,16"/>
                    </StackPanel>
                    <Button x:Name="GenerateBtn" Content="GENERATE DEPTH MAP (RTX)" Height="48" FontWeight="Bold" Click="GenerateBtn_Click" IsEnabled="False" Background="#8B5CF6"/>
                    <StackPanel x:Name="ExportPanel" Visibility="Collapsed" Margin="0,20,0,0">
                        <Button Content="Save 16-bit PNG" Click="Save16Bit_Click" Margin="0,0,0,8" Background="#27272A"/>
                        <Button Content="Save 32-bit EXR" Click="SaveEXR_Click" Margin="0,0,0,8" Background="#27272A"/>
                        <Button Content="Save STL Relief" Click="SaveSTL_Click" Margin="0,0,0,8" Background="#27272A"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>
        <Grid Grid.Column="1" Background="#0A0A0A">
            <Grid.RowDefinitions><RowDefinition Height="50"/><RowDefinition Height="*"/></Grid.RowDefinitions>
            <Border Grid.Row="0" Background="#121212" BorderBrush="#27272A" BorderThickness="0,0,0,1">
                <StackPanel Orientation="Horizontal" Margin="16,0">
                    <RadioButton x:Name="DepthTab" Content="Depth Map" IsChecked="True" Foreground="White" VerticalAlignment="Center" Margin="0,0,16,0" Checked="Tab_Checked"/>
                    <RadioButton x:Name="VariantsTab" Content="4 Variants" Foreground="White" VerticalAlignment="Center" Margin="0,0,16,0" Checked="Tab_Checked"/>
                </StackPanel>
            </Border>
            <Grid Grid.Row="1">
                <Image x:Name="DepthPreview" Stretch="Uniform" Visibility="Collapsed"/>
                <UniformGrid x:Name="VariantsGrid" Columns="2" Visibility="Collapsed" Margin="20">
                    <Border Margin="8" Background="#1A1A1A" CornerRadius="8"><StackPanel><TextBlock Text="Gamma 0.8" FontSize="10" Foreground="#71717A" Margin="8"/><Image x:Name="Var1" Stretch="Uniform"/></StackPanel></Border>
                    <Border Margin="8" Background="#1A1A1A" CornerRadius="8"><StackPanel><TextBlock Text="Gamma 1.0" FontSize="10" Foreground="#71717A" Margin="8"/><Image x:Name="Var2" Stretch="Uniform"/></StackPanel></Border>
                    <Border Margin="8" Background="#1A1A1A" CornerRadius="8"><StackPanel><TextBlock Text="Gamma 1.5" FontSize="10" Foreground="#71717A" Margin="8"/><Image x:Name="Var3" Stretch="Uniform"/></StackPanel></Border>
                    <Border Margin="8" Background="#1A1A1A" CornerRadius="8"><StackPanel><TextBlock Text="Gamma 2.2" FontSize="10" Foreground="#71717A" Margin="8"/><Image x:Name="Var4" Stretch="Uniform"/></StackPanel></Border>
                </UniformGrid>
                <TextBlock x:Name="PlaceholderText" Text="Generate a depth map to see result" TextAlignment="Center" VerticalAlignment="Center" Foreground="#3F3F46"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
