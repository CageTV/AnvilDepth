<Window x:Class="AnvilDepth.MainWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="AnvilDepth V7.20 Checklist" Height="980" Width="1340" Background="#0A0A0A" AllowDrop="True" DragEnter="Window_DragEnter" DragOver="Window_DragOver" Drop="Window_Drop">
    <Grid Background="#0A0A0A">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="390"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Border Grid.Column="0" Background="#18181B" Padding="12">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Image Source="Assets/anvildepth_rtx_logo.jpg" Height="103" Width="110"/>
                    <TextBlock x:Name="GpuStatusText" Text="Ready" Foreground="#22C55E" TextWrapping="Wrap"/>
                    <TextBlock x:Name="DragDebugText" Text="" Foreground="#F59E0B" FontSize="10"/>
                    <Border x:Name="DropZone" Height="120" Background="#1F1F23" CornerRadius="8" AllowDrop="True" DragEnter="DropZone_DragEnter" DragOver="DropZone_DragOver" Drop="DropZone_Drop" MouseDown="DropZone_MouseDown">
                        <Grid>
                            <TextBlock x:Name="DropText" Text="Drop PNG/JPG" Foreground="#52525B" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Image x:Name="InputPreview" Visibility="Collapsed" IsHitTestVisible="False"/>
                        </Grid>
                    </Border>
                    <CheckBox x:Name="AiModelCheck" Content="Use AI" Foreground="White" Checked="Mode_Changed" Unchecked="Mode_Changed" Margin="0,8,0,0"/>
                    <StackPanel Orientation="Horizontal" Margin="18,4,0,0">
                        <RadioButton x:Name="ModelSmallRadio" GroupName="ModelSize" Content="Small" IsChecked="True" Foreground="#AAA" FontSize="11" Margin="0,0,10,0" Checked="ModelSize_Changed"/>
                        <RadioButton x:Name="ModelBaseRadio" GroupName="ModelSize" Content="Base" Foreground="#AAA" FontSize="11" Margin="0,0,10,0" Checked="ModelSize_Changed"/>
                        <RadioButton x:Name="ModelLargeRadio" GroupName="ModelSize" Content="Large" Foreground="#AAA" FontSize="11" Checked="ModelSize_Changed"/>
                    </StackPanel>
                    <TextBlock Text="1. LAB" Foreground="#8B5CF6" FontSize="10" Margin="0,8,0,2"/>
                    <CheckBox x:Name="UseLabCheck" Content="LAB L channel" IsChecked="True" Foreground="#AAA" FontSize="11" Checked="Toggle_Changed" Unchecked="Toggle_Changed"/>
                    <TextBlock Text="2. DE-LIGHT" Foreground="#8B5CF6" FontSize="10" Margin="0,8,0,2"/>
                    <TextBlock Text="Flatten" Foreground="#AAA" FontSize="11"/>
                    <Slider x:Name="FlattenSlider" Minimum="0" Maximum="1" Value="0.35" ValueChanged="Slider_ValueChanged"/>
                    <TextBlock x:Name="FlattenLabel" Text="0.35" FontSize="10" Foreground="#666"/>
                    <TextBlock Text="Radius" Foreground="#AAA" FontSize="11"/>
                    <Slider x:Name="FlattenRadiusSlider" Minimum="5" Maximum="100" Value="40" ValueChanged="Slider_ValueChanged"/>
                    <TextBlock x:Name="FlattenRadiusLabel" Text="40" FontSize="10" Foreground="#666"/>
                    <TextBlock Text="3. FREQ" Foreground="#8B5CF6" FontSize="10" Margin="0,8,0,2"/>
                    <TextBlock Text="Low" Foreground="#AAA" FontSize="11"/>
                    <Slider x:Name="LowFreqSlider" Minimum="0" Maximum="2" Value="1" ValueChanged="Slider_ValueChanged"/>
                    <TextBlock x:Name="LowFreqLabel" Text="1" FontSize="10" Foreground="#666"/>
                    <TextBlock Text="Mid" Foreground="#AAA" FontSize="11"/>
                    <Slider x:Name="MidFreqSlider" Minimum="0" Maximum="2" Value="1" ValueChanged="Slider_ValueChanged"/>
                    <TextBlock x:Name="MidFreqLabel" Text="1" FontSize="10" Foreground="#666"/>
                    <TextBlock Text="High" Foreground="#AAA" FontSize="11"/>
                    <Slider x:Name="HighFreqSlider" Minimum="0" Maximum="3" Value="1" ValueChanged="Slider_ValueChanged"/>
                    <TextBlock x:Name="HighFreqLabel" Text="1" FontSize="10" Foreground="#666"/>
                    <TextBlock Text="Detail" Foreground="#AAA" FontSize="11"/>
                    <Slider x:Name="DetailSlider" Minimum="0" Maximum="1" Value="0.85" ValueChanged="Slider_ValueChanged"/>
                    <TextBlock x:Name="DetailLabel" Text="0.85" FontSize="10" Foreground="#666"/>
                    <TextBlock Text="4. TONE" Foreground="#8B5CF6" FontSize="10" Margin="0,8,0,2"/>
                    <TextBlock Text="Gamma" Foreground="#AAA" FontSize="11"/>
                    <Slider x:Name="GammaSlider" Minimum="0.2" Maximum="3" Value="1" ValueChanged="Slider_ValueChanged"/>
                    <TextBlock x:Name="GammaLabel" Text="1" FontSize="10" Foreground="#666"/>
                    <CheckBox x:Name="PercentileCheck" Content="2%-98% percentile" IsChecked="True" Foreground="#AAA" FontSize="11" Checked="Toggle_Changed" Unchecked="Toggle_Changed"/>
                    <TextBlock Text="Shadows" Foreground="#AAA" FontSize="11"/>
                    <Slider x:Name="ShadowsSlider" Minimum="0.2" Maximum="2.5" Value="1" ValueChanged="Slider_ValueChanged"/>
                    <TextBlock x:Name="ShadowsLabel" Text="1" FontSize="10" Foreground="#666"/>
                    <TextBlock Text="Midtones" Foreground="#AAA" FontSize="11"/>
                    <Slider x:Name="MidtonesSlider" Minimum="0.2" Maximum="2.5" Value="1" ValueChanged="Slider_ValueChanged"/>
                    <TextBlock x:Name="MidtonesLabel" Text="1" FontSize="10" Foreground="#666"/>
                    <TextBlock Text="Highlights" Foreground="#AAA" FontSize="11"/>
                    <Slider x:Name="HighlightsSlider" Minimum="0.2" Maximum="2.5" Value="1" ValueChanged="Slider_ValueChanged"/>
                    <TextBlock x:Name="HighlightsLabel" Text="1" FontSize="10" Foreground="#666"/>
                    <TextBlock Text="5. SEAMLESS" Foreground="#8B5CF6" FontSize="10" Margin="0,8,0,2"/>
                    <CheckBox x:Name="SeamlessCheck" Content="Make Seamless 50%" IsChecked="False" Foreground="#AAA" FontSize="11" Checked="Toggle_Changed" Unchecked="Toggle_Changed"/>
                    <Slider x:Name="SeamBlendSlider" Minimum="0" Maximum="1" Value="0.3" ValueChanged="Slider_ValueChanged"/>
                    <TextBlock x:Name="SeamBlendLabel" Text="0.3" FontSize="10" Foreground="#666"/>
                    <TextBlock Text="6. ZERO" Foreground="#8B5CF6" FontSize="10" Margin="0,8,0,2"/>
                    <CheckBox x:Name="ZeroMidGrayCheck" Content="Zero Mid-Gray 0.5" IsChecked="False" Foreground="#AAA" FontSize="11" Checked="Toggle_Changed" Unchecked="Toggle_Changed"/>
                    <Slider x:Name="ZeroLevelSlider" Minimum="-0.5" Maximum="0.5" Value="0" ValueChanged="Slider_ValueChanged"/>
                    <TextBlock x:Name="ZeroLevelLabel" Text="0" FontSize="10" Foreground="#666"/>
                    <Slider x:Name="StrengthSlider" Minimum="0.2" Maximum="2.5" Value="1" ValueChanged="Slider_ValueChanged"/>
                    <TextBlock x:Name="StrengthLabel" Text="1" FontSize="10" Foreground="#666"/>
                    <CheckBox x:Name="InvertCheck" Content="Invert" Foreground="#AAA" FontSize="11" Checked="Toggle_Changed" Unchecked="Toggle_Changed"/>
                    <CheckBox x:Name="RemoveBgCheck" Content="Remove BG" IsChecked="True" Foreground="#AAA" FontSize="11" Checked="Toggle_Changed" Unchecked="Toggle_Changed"/>
                    <CheckBox x:Name="HighQualityCheck" Content="HQ Tiled" Foreground="#AAA" FontSize="11"/>
                    <Button x:Name="GenerateBtn" Content="GENERATE" Background="#8B5CF6" Foreground="White" Margin="0,12,0,0" Padding="0,12" Click="Generate_Click" IsEnabled="False"/>
                    <Button x:Name="SavePngBtn" Content="Save 16-bit PNG" Margin="0,6,0,0" Click="SavePng_Click" IsEnabled="False"/>
                    <Button x:Name="SaveExrBtn" Content="Save 32-bit EXR" Margin="0,4,0,0" Click="SaveExr_Click" IsEnabled="False"/>
                    <Button x:Name="SaveTiffBtn" Content="Save 32-bit TIFF" Margin="0,4,0,0" Click="SaveTiffBtn_Click" IsEnabled="False"/>
                    <Button x:Name="SaveStlBtn" Content="Save STL" Margin="0,4,0,0" Click="SaveStl_Click" IsEnabled="False"/>
                </StackPanel>
            </ScrollViewer>
        </Border>
        <Border Grid.Column="1" Background="#09090B">
            <Image x:Name="OutputImage" Stretch="Uniform"/>
        </Border>
    </Grid>
</Window>