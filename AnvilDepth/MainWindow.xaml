<Window x:Class="AnvilDepth.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AnvilDepth RTX" Height="860" Width="1280" Background="#0A0A0A" WindowStartupLocation="CenterScreen" AllowDrop="True" DragOver="Window_DragOver" Drop="Window_Drop">
    <Grid>
        <Grid.ColumnDefinitions><ColumnDefinition Width="360"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
        <Border Grid.Column="0" Background="#18181B" Padding="16">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="ANVILDEPTH" FontSize="20" FontWeight="Bold" Foreground="White"/>
                <TextBlock Text="RTX Depth &amp; Relief Tool" FontSize="11" Foreground="#8B5CF6" Margin="0,2,0,16"/>
                <Border Background="#27272A" CornerRadius="8" Padding="10" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="STATUS" FontSize="9" Foreground="#71717A"/>
                        <TextBlock x:Name="GpuStatusText" Text="Ready" FontSize="11" Foreground="#22C55E" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
                <Border x:Name="DropZone" Background="#1F1F23" BorderBrush="#3F3F46" BorderThickness="1" CornerRadius="12" Height="160" Cursor="Hand" AllowDrop="True" DragOver="DropZone_DragOver" Drop="DropZone_Drop" MouseDown="DropZone_MouseDown">
                    <Grid>
                        <TextBlock x:Name="DropText" Text="Drop Image Here&#x0a;or Click to Browse&#x0a;(PNG/JPG/DDS - BC7 OK)" TextAlignment="Center" VerticalAlignment="Center" Foreground="#52525B" FontSize="12"/>
                        <Image x:Name="InputPreview" Stretch="Uniform" Visibility="Collapsed"/>
                    </Grid>
                </Border>
                <StackPanel Margin="0,20,0,0">
                    <CheckBox x:Name="AiModelCheck" Content="Use AI Depth Model" IsChecked="False" Foreground="#D4D4D8" FontSize="12" Margin="0,0,0,12" Checked="Mode_Changed" Unchecked="Mode_Changed"/>
                    <TextBlock Text="DEPTH CONTROLS" FontSize="10" Foreground="#71717A" Margin="0,0,0,12"/>
                    <TextBlock Text="Strength" Foreground="#A1A1AA" FontSize="12"/>
                    <Slider x:Name="StrengthSlider" Minimum="0.2" Maximum="2.5" Value="1.0" Margin="0,4,0,4" ValueChanged="Slider_ValueChanged"/>
                    <TextBlock x:Name="StrengthLabel" Text="1.0" FontSize="10" Foreground="#52525B" Margin="0,0,0,12"/>
                    <TextBlock Text="Detail Boost" Foreground="#A1A1AA" FontSize="12"/>
                    <Slider x:Name="DetailSlider" Minimum="0" Maximum="1" Value="0.85" Margin="0,4,0,4" ValueChanged="Slider_ValueChanged"/>
                    <TextBlock x:Name="DetailLabel" Text="0.85" FontSize="10" Foreground="#52525B" Margin="0,0,0,12"/>
                    <TextBlock Text="Master Gamma" Foreground="#A1A1AA" FontSize="12"/>
                    <Slider x:Name="GammaSlider" Minimum="0.2" Maximum="3.0" Value="1.0" Margin="0,4,0,4" ValueChanged="Slider_ValueChanged"/>
                    <TextBlock x:Name="GammaLabel" Text="1.0" FontSize="10" Foreground="#52525B" Margin="0,0,0,16"/>
                    <TextBlock Text="TONE CURVE" FontSize="10" Foreground="#8B5CF6" Margin="0,0,0,12"/>
                    <TextBlock Text="Shadows" Foreground="#A1A1AA" FontSize="12"/>
                    <Slider x:Name="ShadowsSlider" Minimum="0.2" Maximum="2.5" Value="1.0" Margin="0,4,0,4" ValueChanged="Slider_ValueChanged"/>
                    <TextBlock x:Name="ShadowsLabel" Text="1.0" FontSize="10" Foreground="#52525B" Margin="0,0,0,12"/>
                    <TextBlock Text="Midtones" Foreground="#A1A1AA" FontSize="12"/>
                    <Slider x:Name="MidtonesSlider" Minimum="0.2" Maximum="2.5" Value="1.0" Margin="0,4,0,4" ValueChanged="Slider_ValueChanged"/>
                    <TextBlock x:Name="MidtonesLabel" Text="1.0" FontSize="10" Foreground="#52525B" Margin="0,0,0,12"/>
                    <TextBlock Text="Highlights" Foreground="#A1A1AA" FontSize="12"/>
                    <Slider x:Name="HighlightsSlider" Minimum="0.2" Maximum="2.5" Value="1.0" Margin="0,4,0,4" ValueChanged="Slider_ValueChanged"/>
                    <TextBlock x:Name="HighlightsLabel" Text="1.0" FontSize="10" Foreground="#52525B" Margin="0,0,0,12"/>
                    <CheckBox x:Name="InvertCheck" Content="Invert - White = High" IsChecked="False" Foreground="#D4D4D8" FontSize="12" Margin="0,8,0,8"/>
                    <CheckBox x:Name="RemoveBgCheck" Content="Remove Background to Pure Black" IsChecked="True" Foreground="#D4D4D8" FontSize="12" Margin="0,0,0,8"/>
                    <CheckBox x:Name="HighQualityCheck" Content="High Quality Tiled 2K" IsChecked="False" Foreground="#D4D4D8" FontSize="12" Margin="0,0,0,16"/>
                </StackPanel>
                <Button x:Name="GenerateBtn" Content="GENERATE" Background="#8B5CF6" Foreground="White" FontWeight="Bold" Padding="0,12" Margin="0,0,0,12" Click="Generate_Click" IsEnabled="False"/>
                <TextBlock Text="EXPORT" FontSize="10" Foreground="#71717A" Margin="0,0,0,6"/>
                <Button x:Name="SavePngBtn" Content="Save 16-bit PNG" Margin="0,0,0,6" Click="SavePng_Click" IsEnabled="False"/>
                <Button x:Name="SaveExrBtn" Content="Save 32-bit EXR" Margin="0,0,0,6" Click="SaveExr_Click" IsEnabled="False"/>
                <Button x:Name="SaveStlBtn" Content="Save STL Relief" Margin="0,0,0,6" Click="SaveStl_Click" IsEnabled="False"/>
                <Button x:Name="SaveDdsCompressedBtn" Content="Save DDS DXT1 (Skyrim _p)" Background="#27272A" Foreground="#A1A1AA" Margin="0,6,0,6" Click="SaveDdsCompressed_Click" IsEnabled="False"/>
                <Button x:Name="SaveDdsUncompressedBtn" Content="Save DDS Uncompressed" Background="#27272A" Foreground="#A1A1AA" Margin="0,0,0,6" Click="SaveDdsUncompressed_Click" IsEnabled="False"/>
            </StackPanel>
            </ScrollViewer>
        </Border>
        <Border Grid.Column="1" Background="#09090B">
            <Image x:Name="OutputImage" Stretch="Uniform" Margin="8"/>
        </Border>
    </Grid>
</Window>
